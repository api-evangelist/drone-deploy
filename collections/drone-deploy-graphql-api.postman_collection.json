  "info": {
    "_postman_id": "405e45da-4523-4286-98b5-472da2ee1903",
    "name": "DroneDeploy GraphQL API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "DroneDeploy's public GraphQL API exposes the DroneDeploy reality-capture platform (aerial photogrammetry, ground 360 capture, robotics, exports) through a single POST endpoint at https://www.dronedeploy.com/graphql.\nAll requests are GraphQL queries or mutations sent as JSON to /graphql. Forward, cursor-based pagination is used for all one-to-many relationships (Relay-style edges / nodes / pageInfo with hasNextPage and endCursor). Authentication uses an API key passed via the Authorization: Bearer header. API keys are issued by DroneDeploy Support for existing developers or the Sales team for Developer Partner and Enterprise accounts.\nInteractive exploration is available at https://www.dronedeploy.com/graphiql/ where logged-in DroneDeploy users can introspect the live schema.\n\n\nContact Support:\n Name: DroneDeploy Support",
      "type": "text/plain"
    }
  }
